# SHA-256 hash of your site password
# Generate with: echo -n "your-password" | shasum -a 256
NEXT_PUBLIC_SITE_PASSWORD_HASH=

# Payment handles
NEXT_PUBLIC_VENMO_HANDLE=
NEXT_PUBLIC_ZELLE_EMAIL=
NEXT_PUBLIC_CASHAPP_HANDLE=
NEXT_PUBLIC_STRIPE_PAYMENT_LINK=

# Features
NEXT_PUBLIC_FUND_ITEMS_ENABLED=false

# Database
DATABASE_URL="file:./prisma/dev.db"

# Admin password (SHA-256 hash, same generation method as site password)
ADMIN_PASSWORD_HASH=

# Email (optional — notifications disabled if missing)
RESEND_API_KEY=
COUPLE_EMAIL=
