# SHA-256 hash of your site password
# Generate with: echo -n "your-password" | shasum -a 256
NEXT_PUBLIC_SITE_PASSWORD_HASH=

# Payment handles
NEXT_PUBLIC_VENMO_HANDLE=
NEXT_PUBLIC_ZELLE_EMAIL=
NEXT_PUBLIC_CASHAPP_HANDLE=

# Features
NEXT_PUBLIC_FUND_ITEMS_ENABLED=false

# Database — local SQLite or Turso
DATABASE_URL="file:./prisma/dev.db"
# For Turso (production): DATABASE_URL="libsql://your-db.turso.io"
# TURSO_AUTH_TOKEN=

# Admin password (SHA-256 hash, same generation method as site password)
ADMIN_PASSWORD_HASH=

# Email (optional — notifications disabled if missing)
RESEND_API_KEY=
COUPLE_EMAIL=

# Admin SSO (optional — password auth by default)
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# AUTH_SECRET=  # Random string: openssl rand -base64 32
# ADMIN_EMAILS=  # Comma-separated allowed emails
# NEXT_PUBLIC_ADMIN_SSO_ENABLED=true
